# Copy to .env and fill in your Harper Fabric cluster credentials.
# Get both URLs from fabric.harper.fast → your cluster → Config tab.
#
# CLI_TARGET   = Operations API URL. Used by the `harperdb` CLI to
#                deploy_component, describe_all, etc. On Fabric this
#                is typically a region-specific host on port :9925.
#
# CLI_APP_URL  = Application URL. Used for REST probes against your
#                deployed components: GET /Pipeline/, GET /<Table>/,
#                GET /<PipelineId>Run. On Fabric this is typically
#                the short cluster hostname, no explicit port.
#
# These are usually DIFFERENT host:port values on Fabric. If you set
# them to the same value, the Node preflight will warn you.

CLI_TARGET='https://us-west1-a-1.your-cluster-id.cluster.harper.fast:9925'
CLI_APP_URL='https://your-cluster-id.cluster.harper.fast'
CLI_TARGET_USERNAME='your-cluster-username'
CLI_TARGET_PASSWORD='your-cluster-password'
